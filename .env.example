# Required in production for strict origin validation.
APP_URL=https://your-app.example.com

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPADATA_API_KEY=your_supadata_api_key
SUPADATA_PREFERRED_LANGS=ru,en
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODELS=gemini-2.5-flash

# Test-only auth bypass for local Playwright runs. Keep disabled outside tests.
TEST_BYPASS_AUTH=0
TEST_BYPASS_USER_EMAIL=e2e@example.com
TEST_BYPASS_USER_NAME=E2E User
TEST_BYPASS_CREDITS=9
